          "path": "src/server/MatchResultCertificate.ts",
          "includes": ["MatchResultQuorum", "verifyMatchResultCertificate"]
        },
        {
          "path": "src/server/GameServer.ts",
          "includes": [
            "resultCertificate = buildMatchResultCertificate",
            "this.recordProgressionOutcome()",
            "this.archiveGame()"
          ]
        }
      ]
    },
    {
      "id": "canonical-ai-receipts",
