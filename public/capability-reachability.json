{
  "schemaVersion": "1.0",
  "project": "vaultfront",
  "releasePosture": "implemented-local-unlaunched",
  "truthRule": "A capability is reachable only when every checked-in source token below is present; this manifest never claims a live public runtime.",
  "capabilities": [
