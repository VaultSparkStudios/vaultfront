      "id": "command-center",
      "audience": "human-player",
      "evidence": [
        {
          "path": "src/client/Navigation.ts",
          "includes": [
            "await import(\"./CommandCenter\")",
            "pageId === \"page-command-center\""
          ]
        },
        {
          "path": "index.html",
          "includes": ["id=\"page-command-center\"", "<command-center"]
        },
        {
          "path": "src/client/FeatureLiveness.ts",
          "includes": ["featureLivenessGraph", "page-command-center"]
        }
      ]
    },
    {
      "id": "certified-match-outcomes",
      "audience": "human-player",
      "evidence": [
