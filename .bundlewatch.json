{
  "files": [
    {
      "path": "static/assets/*.js",
      "maxSize": "500 kB",
      "compression": "gzip"
    },
    {
      "path": "static/assets/*.css",
      "maxSize": "150 kB",
      "compression": "gzip"
    }
  ],
  "initialEntry": {
    "html": "static/index.html",
    "maxGzipBytes": 738885,
    "maxBrotliBytes": 586751
  },
  "media": {
    "root": "static/assets",
    "extensions": [
      ".mp3",
      ".png",
      ".webp",
      ".jpg",
      ".jpeg",
      ".gif",
      ".svg",
      ".woff",
      ".woff2",
      ".ttf",
      ".eot"
    ],
    "maxTotalBytes": 14678071,
    "maxFileBytes": 4101503
  },
  "defaultCompression": "gzip"
}
